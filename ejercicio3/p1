import Data.Char (isUpper)

hayNegativo :: [Int] -> Bool
hayNegativo = any (<0)

todosPares :: [Int] -> Bool
todosPares = all even

nombresCorrectos :: [String] -> Bool
nombresCorrectos = all (\x -> isUpper (head x))

--test
hayNegativo [-1, 3, 2]
hayNegativo [1,2,3]

todosPares[2,4,6]
todosPares[1, 4, 8]

nombresCorrectos ["Carlos", "Samuel", "Luis"]
nombresCorrectos ["Carlos", "Samuel", "luis"]

