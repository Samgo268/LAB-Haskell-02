menoresQue100 :: [Int] -> [Int]
menoresQue100 = takeWhile (\x -> x < 100)

sinCerosIniciales :: [Int] -> [Int]
sinCerosIniciales = dropWhile (\x -> x == 0)

--test
menoresQue100 [1, 32, 75, 90, 95, 101, 209]
sinCerosIniciales [0, 0, 0, 1, 4]
