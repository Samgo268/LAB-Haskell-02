miLength :: [a] -> Int
miLength [] = 0
miLength (_:xs) = 1 + miLength xs

miLast :: [a] -> a
miLast [x] = x
miLast (_:xs) = miLast xs

duplicar :: [Int] -> [Int]
duplicar [] = []
duplicar (x:xs) = x*2 : duplicar xs

eliminarPares :: [Int] -> [Int]
eliminarPares [] = []
eliminarPares (x:xs)
    | mod x 2 == 0 = eliminarPares xs
    | otherwise = x : eliminarPares xs
